{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BreedLog",
  "version": "1.0.2",
  "identifier": "com.stitchworx.breedlog",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://127.0.0.1:5000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BreedLog",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "STITCH WORX",
    "category": "Business",
    "shortDescription": "BreedLog livestock management desktop application",
    "longDescription": "BreedLog for Windows delivers offline-capable livestock records, breeding data, exports, and synchronized herd management.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
